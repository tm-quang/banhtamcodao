# Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to git!

# ===========================================
# SUPABASE CONFIGURATION (REQUIRED)
# ===========================================
# Get these from your Supabase project settings
# Dashboard > Settings > API

NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ===========================================
# CLOUDINARY CONFIGURATION (OPTIONAL)
# ===========================================
# For image upload and management
# Get these from Cloudinary dashboard

NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ===========================================
# APPLICATION CONFIGURATION
# ===========================================

# Application name
NEXT_PUBLIC_APP_NAME=Bánh Tâm Cô Đào

# Application URL (for production)
NEXT_PUBLIC_APP_URL=http://localhost:3300

# Node environment (development, production, test)
NODE_ENV=development

# ===========================================
# SECURITY CONFIGURATION (OPTIONAL)
# ===========================================

# JWT Secret (for custom JWT if needed)
# JWT_SECRET=your_random_secret_key_here

# Session secret
# SESSION_SECRET=your_session_secret_here

# CSRF Token Secret
# CSRF_SECRET=your_csrf_secret_here

# ===========================================
# RATE LIMITING (OPTIONAL)
# ===========================================

# Enable rate limiting (true/false)
# ENABLE_RATE_LIMITING=true

# Rate limit window in milliseconds
# RATE_LIMIT_WINDOW_MS=900000

# Max requests per window
# RATE_LIMIT_MAX_REQUESTS=100

# ===========================================
# EMAIL CONFIGURATION (OPTIONAL)
# ===========================================
# For sending emails (if using custom email service)

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password

# ===========================================
# PAYMENT GATEWAY (OPTIONAL)
# ===========================================
# For payment processing

# VNPAY_TMN_CODE=your_vnpay_tmn_code
# VNPAY_HASH_SECRET=your_vnpay_hash_secret
# VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html

# ===========================================
# ANALYTICS (OPTIONAL)
# ===========================================

# Google Analytics
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Facebook Pixel
# NEXT_PUBLIC_FB_PIXEL_ID=your_pixel_id

# ===========================================
# DEVELOPMENT TOOLS (OPTIONAL)
# ===========================================

# Enable debug mode
# DEBUG=false

# Enable verbose logging
# VERBOSE_LOGGING=false

# ===========================================
# NOTES
# ===========================================
# 1. Never commit this file with real values to git
# 2. Keep your secrets safe and rotate them regularly
# 3. Use different values for development and production
# 4. For production, set these in your hosting platform (Vercel, etc.)
# 5. Required variables are marked as (REQUIRED)
# 6. Optional variables can be left empty if not needed
